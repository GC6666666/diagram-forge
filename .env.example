# Environment variables for Diagram Forge
# Copy this to .env and fill in your values

# ─── API Keys ───────────────────────────────────────────────────────────────
# Required: Anthropic API key for Claude
ANTHROPIC_API_KEY=sk-ant-

# ─── Server ─────────────────────────────────────────────────────────────────
# Host/port (default: 0.0.0.0:8000)
HOST=0.0.0.0
PORT=8000

# ─── Security ────────────────────────────────────────────────────────────────
# Required: Pre-shared API key for authentication
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
DF_API_KEY=

# ─── Rate Limits ─────────────────────────────────────────────────────────────
# Requests per minute per API key
DF_RATE_LIMIT_RPM=100
# Requests per minute per IP (unauthenticated)
DF_RATE_LIMIT_IP_RPM=30
# Burst size
DF_RATE_LIMIT_BURST=20

# ─── Storage ─────────────────────────────────────────────────────────────────
# Root directory for data (input, output, temp files)
DF_DATA_ROOT=/tmp/diagram-forge

# ─── Logging ─────────────────────────────────────────────────────────────────
# Log level: DEBUG, INFO, WARNING, ERROR
LOG_LEVEL=INFO
